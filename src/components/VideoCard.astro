---
interface Props {
  slug: string;
  title: string;
  channel: string;
  channelSlug: string;
  guests: string[];
  summary: string;
  tags: string[];
  duration: number;
  publishedAt: string;
  hidden?: boolean;
}

const { slug, title, channel, channelSlug, guests, duration, publishedAt, hidden } = Astro.props;

const minutes = Math.floor(duration / 60);
const durationStr = minutes >= 60 ? `${Math.floor(minutes / 60)}h${minutes % 60 > 0 ? ` ${minutes % 60}m` : ''}` : `${minutes}m`;
const guestSlugs = guests.map(g => g.toLowerCase().replace(/\s+/g, '-'));
const searchText = [title, channel, ...guests].join(' ').toLowerCase();
---
<a href={`/v/${slug}`} class="video-card" data-channel={channelSlug} data-guests={guestSlugs.join(',')} data-search={searchText} data-hidden={hidden || undefined} style={hidden ? 'display:none' : undefined}>
  <h3 class="card-title">{title}</h3>
  <div class="card-bottom">
    <span class="card-guests">{guests.length > 0 ? guests.join(', ') : channel}</span>
    <div class="card-pills">
      <span class="pill">{durationStr}</span>
      <span class="pill">{publishedAt.slice(0, 7)}</span>
    </div>
  </div>
</a>

<style>
  .video-card {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 16px 18px 14px;
    border: 1px solid rgba(0, 0, 0, 0.04);
    border-radius: 10px;
    background: #fff;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.02);
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    border-left: 2px solid rgba(0, 0, 0, 0.04);
  }
  .video-card:hover {
    border-color: rgba(0, 0, 0, 0.04);
    border-left-color: #c8a96e;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
    transform: translateY(-1px);
  }
  .card-title {
    font-size: 13px;
    font-weight: 600;
    line-height: 1.45;
    color: #1a1a18;
    margin-bottom: 10px;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .card-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
  }
  .card-guests {
    font-size: 11px;
    color: #8b8b85;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .card-pills {
    display: flex;
    gap: 4px;
    flex-shrink: 0;
  }
  .pill {
    font-size: 10px;
    font-weight: 500;
    color: #a3a39e;
    background: rgba(0, 0, 0, 0.025);
    padding: 2px 7px;
    border-radius: 4px;
    letter-spacing: 0.2px;
    white-space: nowrap;
  }
</style>
