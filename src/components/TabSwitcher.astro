---
import BilingualPanel from './BilingualPanel.astro';

interface Props {
  memoHtml: string;
  translationHtml: string;
  originalHtml: string;
  bilingualPairs?: Array<{ zh: string; en: string }>;
}

const { memoHtml, translationHtml, originalHtml, bilingualPairs } = Astro.props;
---
<div class="tab-container">
  <div class="tab-nav">
    <button class="tab-btn active" data-tab="memo">纪要</button>
    <button class="tab-btn" data-tab="translation">双语对照</button>
    <button class="tab-btn" data-tab="original">英文原文</button>
  </div>
  <div class="tab-panels">
    <div class="tab-panel active" id="panel-memo" set:html={memoHtml} />
    <div class="tab-panel" id="panel-translation">
      {bilingualPairs && bilingualPairs.length > 0
        ? <BilingualPanel pairs={bilingualPairs} />
        : <Fragment set:html={translationHtml} />
      }
    </div>
    <div class="tab-panel" id="panel-original" set:html={originalHtml} />
  </div>
</div>

<style>
  .tab-nav {
    position: sticky;
    top: 60px;
    z-index: 50;
    background: rgba(245, 244, 240, 0.92);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid #f0efeb;
    display: flex;
    gap: 0;
    margin: 0 0 32px;
  }
  .tab-btn {
    background: none;
    border: none;
    font: inherit;
    font-size: 14px;
    font-weight: 450;
    color: #a3a39e;
    padding: 14px 20px;
    cursor: pointer;
    border-bottom: 2px solid transparent;
    transition: all 0.2s;
  }
  .tab-btn:hover { color: #6b6b66; }
  .tab-btn.active {
    color: #1a1a18;
    font-weight: 600;
    border-bottom-color: #1a1a18;
  }
  .tab-panel { display: none; }
  .tab-panel.active { display: block; }

  .tab-panel :global(h1) { font-size: 20px; font-weight: 650; margin: 32px 0 12px; color: #1a1a18; }
  .tab-panel :global(h2) {
    font-size: 16px;
    font-weight: 600;
    margin: 36px 0 12px;
    padding-bottom: 8px;
    border-bottom: 1px solid #f0efeb;
    color: #2d2d2a;
  }
  .tab-panel :global(h3) { font-size: 15px; font-weight: 600; margin: 24px 0 8px; color: #2d2d2a; }
  .tab-panel :global(p) { margin: 10px 0; color: #3d3d3a; font-size: 15px; line-height: 1.8; }
  .tab-panel :global(ul), .tab-panel :global(ol) { padding-left: 20px; margin: 10px 0; }
  .tab-panel :global(li) { margin: 6px 0; color: #3d3d3a; font-size: 15px; line-height: 1.8; }
  .tab-panel :global(blockquote) {
    border-left: 2px solid #e0dfdb;
    padding-left: 16px;
    color: #6b6b66;
    margin: 16px 0;
    font-style: italic;
  }
  .tab-panel :global(code) { background: #f7f6f3; padding: 2px 6px; border-radius: 4px; font-size: 0.88em; color: #6b6b66; }
  .tab-panel :global(strong) { font-weight: 600; color: #1a1a18; }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const btns = document.querySelectorAll('.tab-btn');
    const panels = document.querySelectorAll('.tab-panel');

    function switchTab(tabId: string) {
      btns.forEach(b => b.classList.toggle('active', b.getAttribute('data-tab') === tabId));
      panels.forEach(p => p.classList.toggle('active', p.id === `panel-${tabId}`));
      window.location.hash = tabId;
    }

    btns.forEach(btn => {
      btn.addEventListener('click', () => switchTab(btn.getAttribute('data-tab')!));
    });

    const hash = window.location.hash.slice(1);
    if (hash && ['memo', 'translation', 'original'].includes(hash)) {
      switchTab(hash);
    }
  });
</script>
