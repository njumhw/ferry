---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import VideoCard from '../../components/VideoCard.astro';

export async function getStaticPaths() {
  const allVideos = await getCollection('videos');
  const byChannel = new Map<string, { name: string; videos: typeof allVideos }>();
  for (const video of allVideos) {
    const { channel_slug, channel } = video.data.metadata;
    if (!byChannel.has(channel_slug)) byChannel.set(channel_slug, { name: channel, videos: [] });
    byChannel.get(channel_slug)!.videos.push(video);
  }
  return [...byChannel.entries()].map(([slug, { name, videos }]) => ({
    params: { slug },
    props: { name, videos: videos.sort((a, b) => b.data.metadata.published_at.localeCompare(a.data.metadata.published_at)) },
  }));
}

const { name, videos } = Astro.props;
---
<Base title={name}>
  <section class="listing-page">
    <header class="page-header">
      <a href="/" class="back">&larr; 返回首页</a>
      <h1>{name}</h1>
    </header>

    {videos.length > 0 ? (
      <div class="video-grid">
        {videos.map(video => (
          <VideoCard
            slug={video.id}
            title={video.data.metadata.title}
            channel={video.data.metadata.channel}
            channelSlug={video.data.metadata.channel_slug}
            guests={video.data.metadata.guests}
            summary={video.data.summary_zh}
            tags={video.data.tags}
            duration={video.data.metadata.duration_seconds}
            publishedAt={video.data.metadata.published_at}
          />
        ))}
      </div>
    ) : (
      <p class="empty">暂无内容</p>
    )}
  </section>
</Base>

<style>
  .listing-page { padding-top: 40px; }
  .page-header { margin-bottom: 32px; }
  .back {
    display: inline-block;
    font-size: 13px;
    color: #a3a39e;
    margin-bottom: 12px;
    transition: color 0.15s;
  }
  .back:hover { color: #2d2d2a; }
  .page-header h1 { font-size: 20px; font-weight: 650; color: #1a1a18; letter-spacing: -0.3px; }
  .video-grid { display: flex; flex-direction: column; gap: 16px; }
  .empty { color: #a3a39e; font-size: 14px; }
</style>
