---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import VideoCard from '../../components/VideoCard.astro';
import { channels } from '../../data/channels';

export function getStaticPaths() {
  return Object.keys(channels).map(slug => ({ params: { slug } }));
}

const { slug } = Astro.params;
const channel = channels[slug as keyof typeof channels];

const allVideos = await getCollection('videos');
const videos = allVideos
  .filter(v => v.data.metadata.channel_slug === slug)
  .sort((a, b) => b.data.metadata.published_at.localeCompare(a.data.metadata.published_at));
---
<Base title={channel.name} description={channel.description}>
  <section class="channel-page">
    <header class="page-header">
      <h1>{channel.name}</h1>
      <p class="desc">{channel.description}</p>
      <a href={channel.url} class="external" target="_blank" rel="noopener">YouTube →</a>
    </header>

    {videos.length > 0 ? (
      <div class="video-grid">
        {videos.map(video => (
          <VideoCard
            slug={video.id}
            title={video.data.metadata.title}
            channel={video.data.metadata.channel}
            guests={video.data.metadata.guests}
            summary={video.data.summary_zh}
            tags={video.data.tags}
            duration={video.data.metadata.duration_seconds}
            publishedAt={video.data.metadata.published_at}
          />
        ))}
      </div>
    ) : (
      <p class="empty">暂无内容</p>
    )}
  </section>
</Base>

<style>
  .channel-page { padding-top: 32px; }
  .page-header { margin-bottom: 32px; }
  .page-header h1 { font-size: 24px; font-weight: 700; margin-bottom: 8px; }
  .desc { color: #666; font-size: 15px; margin-bottom: 8px; }
  .external { font-size: 13px; color: #888; }
  .external:hover { color: #1d4ed8; }
  .video-grid { display: flex; flex-direction: column; gap: 16px; }
  .empty { color: #999; font-size: 14px; }
</style>
