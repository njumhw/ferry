---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import TabSwitcher from '../../components/TabSwitcher.astro';
import { marked } from 'marked';

export async function getStaticPaths() {
  const videos = await getCollection('videos');
  return videos.map(video => ({
    params: { slug: video.id },
    props: { video },
  }));
}

const { video } = Astro.props;
const { metadata, memo_zh, translation_zh, original_en, tags } = video.data;

const minutes = Math.floor(metadata.duration_seconds / 60);
const durationStr = minutes >= 60 ? `${Math.floor(minutes / 60)}h ${minutes % 60}m` : `${minutes}m`;

let memoMd = '';
if (memo_zh.intro) {
  memoMd += memo_zh.intro + '\n\n';
}
for (const topic of memo_zh.topics) {
  memoMd += `## ${topic.id}. ${topic.title}\n\n`;
  memoMd += topic.body_md + '\n\n';
}

const memoHtml = await marked.parse(memoMd);
const translationHtml = await marked.parse(translation_zh.body_md);
const originalHtml = await marked.parse(original_en.body_md);
---
<Base title={metadata.title} description={video.data.summary_zh} ogType="article">
  <article class="video-detail">
    <header class="detail-header">
      <a href="/" class="back">&larr; 返回首页</a>
      <h1>{metadata.title}</h1>
      <div class="meta-line">
        <a href={`/channel/${metadata.channel_slug}`} class="meta-link">{metadata.channel}</a>
        <span class="sep">/</span>
        {metadata.guests.map((g, i) => (
          <><a href={`/guest/${g.toLowerCase().replace(/\s+/g, '-')}`} class="meta-link">{g}</a>{i < metadata.guests.length - 1 && ', '}</>
        ))}
        {metadata.host && <><span class="sep">/</span><span class="host">Host: {metadata.host}</span></>}
        <span class="sep">/</span>
        <span>{durationStr}</span>
        <span class="sep">/</span>
        <span>{metadata.published_at}</span>
        <span class="sep">/</span>
        <a href={metadata.source_url} target="_blank" rel="noopener noreferrer" class="meta-link source-link">YouTube 原片 &nearr;</a>
        <span class="sep">/</span>
        <button class="copy-link" id="copy-link">
          <svg width="13" height="13" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M6.5 10.5L3.5 10.5C2.4 10.5 1.5 9.6 1.5 8.5L1.5 3.5C1.5 2.4 2.4 1.5 3.5 1.5L8.5 1.5C9.6 1.5 10.5 2.4 10.5 3.5L10.5 6.5"/>
            <rect x="5.5" y="5.5" width="9" height="9" rx="2"/>
          </svg>
          <span class="copy-text">复制链接</span>
        </button>
        <span class="sep">/</span>
        <button class="download-md" id="download-md">
          <svg width="13" height="13" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M8 2v9m0 0l-3-3m3 3l3-3M2.5 12.5h11"/>
          </svg>
          <span>下载 MD</span>
        </button>
      </div>
      <div class="tags">
        {tags.map(tag => <a href={`/tag/${tag.toLowerCase().replace(/\s+/g, '-')}`} class="tag">{tag}</a>)}
      </div>
    </header>

    <TabSwitcher memoHtml={memoHtml} translationHtml={translationHtml} originalHtml={originalHtml} />
  </article>
</Base>

<style>
  .video-detail { padding-top: 40px; }
  .detail-header { margin-bottom: 32px; }
  .back {
    display: inline-block;
    font-size: 13px;
    color: #a3a39e;
    margin-bottom: 12px;
    transition: color 0.15s;
  }
  .back:hover { color: #2d2d2a; }
  .source-link { color: #6b6b66; }
  h1 {
    font-size: 22px;
    font-weight: 650;
    line-height: 1.4;
    margin-bottom: 12px;
    color: #1a1a18;
    letter-spacing: -0.3px;
  }
  .meta-line { font-size: 13px; color: #a3a39e; margin-bottom: 16px; }
  .meta-link { color: #6b6b66; transition: color 0.15s; }
  .meta-link:hover { color: #2d2d2a; opacity: 1; }
  .sep { margin: 0 8px; opacity: 0.4; }
  .host { color: #a3a39e; }
  .tags { display: flex; flex-wrap: wrap; gap: 6px; }
  .tag {
    font-size: 12px;
    font-weight: 450;
    padding: 3px 10px;
    border-radius: 4px;
    background: #f7f6f3;
    color: #8b8b85;
    transition: all 0.15s;
  }
  .tag:hover { background: #eeedea; color: #6b6b66; opacity: 1; }
  .copy-link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-family: inherit;
    font-size: 13px;
    color: #6b6b66;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    transition: color 0.15s;
    vertical-align: baseline;
  }
  .copy-link:hover { color: #2d2d2a; }
  .copy-link svg { position: relative; top: 1px; }
  .download-md {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-family: inherit;
    font-size: 13px;
    color: #6b6b66;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    transition: color 0.15s;
    vertical-align: baseline;
  }
  .download-md:hover { color: #2d2d2a; }
  .download-md svg { position: relative; top: 1px; }
</style>

<script is:inline define:vars={{ memoMd, translationMd: translation_zh.body_md, originalMd: original_en.body_md, title: metadata.title }}>
  document.getElementById('copy-link').addEventListener('click', function() {
    var text = this.querySelector('.copy-text');
    navigator.clipboard.writeText(window.location.href).then(function() {
      text.textContent = '已复制';
      setTimeout(function() { text.textContent = '复制链接'; }, 1500);
    });
  });

  document.getElementById('download-md').addEventListener('click', function() {
    var content = '# ' + title + '\n\n';
    content += '---\n\n';
    content += '## 纪要\n\n' + memoMd + '\n\n';
    content += '---\n\n';
    content += '## 中文翻译\n\n' + translationMd + '\n\n';
    content += '---\n\n';
    content += '## 英文原文\n\n' + originalMd + '\n';

    var blob = new Blob([content], { type: 'text/markdown;charset=utf-8' });
    var url = URL.createObjectURL(blob);
    var a = document.createElement('a');
    a.href = url;
    a.download = title.replace(/[^\w\s一-鿿-]/g, '').replace(/\s+/g, '-').substring(0, 80) + '.md';
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    URL.revokeObjectURL(url);
  });
</script>
