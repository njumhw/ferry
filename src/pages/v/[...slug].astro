---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import TabSwitcher from '../../components/TabSwitcher.astro';
import { marked } from 'marked';

export async function getStaticPaths() {
  const videos = await getCollection('videos');
  return videos.map(video => ({
    params: { slug: video.id },
    props: { video },
  }));
}

const { video } = Astro.props;
const { metadata, memo_zh, translation_zh, original_en, tags } = video.data;

const minutes = Math.floor(metadata.duration_seconds / 60);
const durationStr = minutes >= 60 ? `${Math.floor(minutes / 60)}h ${minutes % 60}m` : `${minutes}m`;

// Build memo HTML from topics
let memoMd = '';
if (memo_zh.intro) {
  memoMd += memo_zh.intro + '\n\n';
}
for (const topic of memo_zh.topics) {
  memoMd += `## ${topic.id}. ${topic.title}\n\n`;
  memoMd += topic.body_md + '\n\n';
}

const memoHtml = await marked.parse(memoMd);
const translationHtml = await marked.parse(translation_zh.body_md);
const originalHtml = await marked.parse(original_en.body_md);
---
<Base title={metadata.title} description={video.data.summary_zh}>
  <article class="video-detail">
    <header class="detail-header">
      <div class="meta-line">
        <a href={`/channel/${metadata.channel_slug}`}>{metadata.channel}</a>
        <span class="dot">&middot;</span>
        <span>{durationStr}</span>
        <span class="dot">&middot;</span>
        <span>{metadata.published_at}</span>
      </div>
      <h1>{metadata.title}</h1>
      <p class="guests">
        {metadata.guests.map(g => <a href={`/guest/${g.toLowerCase().replace(/\s+/g, '-')}`}>{g}</a>)}
        {metadata.host && <span class="host"> &middot; Host: {metadata.host}</span>}
      </p>
      <div class="tags">
        {tags.map(tag => <a href={`/tag/${tag.toLowerCase().replace(/\s+/g, '-')}`} class="tag">{tag}</a>)}
      </div>
    </header>

    <TabSwitcher memoHtml={memoHtml} translationHtml={translationHtml} originalHtml={originalHtml} />
  </article>
</Base>

<style>
  .video-detail { padding-top: 32px; }
  .detail-header { margin-bottom: 24px; }
  .meta-line { font-size: 14px; color: #888; margin-bottom: 8px; }
  .meta-line a { color: #1d4ed8; }
  .dot { margin: 0 8px; }
  h1 { font-size: 24px; font-weight: 700; line-height: 1.3; margin-bottom: 8px; }
  .guests { font-size: 15px; color: #555; margin-bottom: 12px; }
  .guests a { color: #1d4ed8; }
  .host { color: #888; }
  .tags { display: flex; flex-wrap: wrap; gap: 6px; }
  .tag {
    font-size: 12px;
    padding: 3px 10px;
    border-radius: 4px;
    background: #f0f0ec;
    color: #666;
  }
  .tag:hover { background: #e5e5e0; text-decoration: none; }
</style>
