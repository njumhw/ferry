---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import VideoCard from '../../components/VideoCard.astro';

export async function getStaticPaths() {
  const allVideos = await getCollection('videos');
  const guestMap = new Map<string, string>();

  for (const video of allVideos) {
    for (const guest of video.data.metadata.guests) {
      const slug = guest.toLowerCase().replace(/\s+/g, '-');
      guestMap.set(slug, guest);
    }
  }

  return [...guestMap.entries()].map(([slug, name]) => ({
    params: { slug },
    props: { name },
  }));
}

const { slug } = Astro.params;
const { name } = Astro.props;

const allVideos = await getCollection('videos');
const videos = allVideos
  .filter(v => v.data.metadata.guests.some(g => g.toLowerCase().replace(/\s+/g, '-') === slug))
  .sort((a, b) => b.data.metadata.published_at.localeCompare(a.data.metadata.published_at));
---
<Base title={name}>
  <section class="listing-page">
    <header class="page-header">
      <h1>{name}</h1>
      <p class="count">{videos.length} 期</p>
    </header>

    <div class="video-grid">
      {videos.map(video => (
        <VideoCard
          slug={video.id}
          title={video.data.metadata.title}
          channel={video.data.metadata.channel}
          channelSlug={video.data.metadata.channel_slug}
          guests={video.data.metadata.guests}
          summary={video.data.summary_zh}
          tags={video.data.tags}
          duration={video.data.metadata.duration_seconds}
          publishedAt={video.data.metadata.published_at}
        />
      ))}
    </div>
  </section>
</Base>

<style>
  .listing-page { padding-top: 40px; }
  .page-header { margin-bottom: 32px; }
  .page-header h1 { font-size: 20px; font-weight: 650; color: #1a1a18; margin-bottom: 4px; letter-spacing: -0.3px; }
  .count { color: #a3a39e; font-size: 13px; }
  .video-grid { display: flex; flex-direction: column; }
</style>
