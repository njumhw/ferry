---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import VideoCard from '../components/VideoCard.astro';
import { channels } from '../data/channels';

const allVideos = await getCollection('videos');
const sorted = allVideos.sort((a, b) =>
  b.data.metadata.published_at.localeCompare(a.data.metadata.published_at)
);
---
<Base title="首页">
  <section class="hero">
    <h1>Ferry</h1>
    <p class="tagline">把值得读的 AI 对话摆渡过来。</p>
  </section>

  <section class="channels">
    <h2>频道</h2>
    <div class="channel-list">
      {Object.entries(channels).map(([slug, ch]) => (
        <a href={`/channel/${slug}`} class="channel-badge">{ch.name}</a>
      ))}
    </div>
  </section>

  <section class="videos">
    <h2>最新内容</h2>
    <div class="video-grid">
      {sorted.map(video => (
        <VideoCard
          slug={video.id}
          title={video.data.metadata.title}
          channel={video.data.metadata.channel}
          guests={video.data.metadata.guests}
          summary={video.data.summary_zh}
          tags={video.data.tags}
          duration={video.data.metadata.duration_seconds}
          publishedAt={video.data.metadata.published_at}
        />
      ))}
    </div>
  </section>
</Base>

<style>
  .hero { padding: 48px 0 32px; }
  .hero h1 { font-size: 36px; font-weight: 800; letter-spacing: -1px; }
  .tagline { color: #666; margin-top: 8px; font-size: 16px; }

  .channels { margin: 32px 0; }
  .channels h2 { font-size: 16px; font-weight: 600; margin-bottom: 12px; color: #444; }
  .channel-list { display: flex; flex-wrap: wrap; gap: 8px; }
  .channel-badge {
    font-size: 13px;
    padding: 4px 12px;
    border-radius: 16px;
    background: #f0f0ec;
    color: #555;
    transition: background 0.15s;
  }
  .channel-badge:hover { background: #e5e5e0; text-decoration: none; }

  .videos { margin-top: 40px; }
  .videos h2 { font-size: 16px; font-weight: 600; margin-bottom: 16px; color: #444; }
  .video-grid { display: flex; flex-direction: column; gap: 16px; }
</style>
